{
  "name": "lego-shop",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
  "dev": "concurrently -n WEB,ADMIN,API -c blue,magenta,green \"pnpm --filter web dev\" \"pnpm --filter admin dev\" \"pnpm --filter backend start:dev\"",
  "dev:turbo": "turbo run dev --parallel",
  "build": "turbo run build",
  "lint": "turbo run lint",
  "typecheck": "turbo run typecheck",
  "dev:web": "pnpm --filter web dev",
  "dev:admin": "pnpm --filter admin dev",
  "dev:backend": "pnpm --filter backend start:dev"
},
  "devDependencies": {
    "concurrently": "^10.0.0",
    "prettier": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}