generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  active
  inactive
}

enum FrameOptionType {
  size
  color
  template
  material
  glass
  mat
  accessory
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipping
  completed
  cancelled
}

enum PaymentMethod {
  COD
  PAYOS
}

enum PaymentStatus {
  unpaid
  pending
  deposit_pending
  deposit_paid
  paid
  failed
  cancelled
  refunded
}

enum ShippingStatus {
  pending
  preparing
  shipping
  delivered
  cancelled
}

enum PaymentType {
  full_payment
  cod_deposit
}

enum VoucherDiscountType {
  percentage
  fixed
}

enum OrderStatusHistoryType {
  ORDER_STATUS
  PAYMENT_STATUS
  SHIPPING_STATUS
  NOTE
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         String   @default("admin")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orderStatusHistories OrderStatusHistory[]
}

model Product {
  id          String        @id @default(uuid())
  name        String
  slug        String        @unique
  description String?
  basePrice   Int
  images      String[]      @default([])
  productType String        @default("finished")
  componentConfig Json?
  status      ProductStatus @default(active)
  featured    Boolean       @default(false)

  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]

  @@index([productType, status])
  @@index([collectionId])
}

model TemplateCategory {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  templates Template[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id         String        @id @default(uuid())
  name       String
  imageUrl   String?
  configJson Json?
  status     ProductStatus @default(active)

  categoryId String?
  category   TemplateCategory? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccessoryCategory {
  id          String      @id @default(uuid())
  name        String
  slug        String      @unique
  accessories Accessory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Accessory {
  id       String        @id @default(uuid())
  name     String
  price    Int           @default(0)
  imageUrl String?
  iconUrl  String?
  status   ProductStatus @default(active)

  categoryId String?
  category   AccessoryCategory? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Banner {
  id        String        @id @default(uuid())
  title     String?
  imageUrl  String
  linkUrl   String?
  sortOrder Int           @default(0)
  status    ProductStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FrameBackground {
  id            String        @id @default(uuid())
  title         String
  description   String?
  instructions  String?
  imageUrl      String
  contentFields Json?
  frameOptionIds String[]      @default([])
  sortOrder     Int           @default(0)
  status        ProductStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, sortOrder])
}

model Collection {
  id          String        @id @default(uuid())
  name        String
  slug        String        @unique
  description String?
  imageUrl    String?
  status      ProductStatus @default(active)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Character {
  id        String        @id @default(uuid())
  name      String
  price     Int           @default(10000)
  imageUrl  String?
  sortOrder Int           @default(0)
  status    ProductStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, sortOrder])
}

model FrameSize {
  id      String        @id @default(uuid())
  label   String
  price   Int
  popular Boolean       @default(false)
  status  ProductStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FrameColor {
  id       String        @id @default(uuid())
  name     String
  colorHex String?
  status   ProductStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FrameOption {
  id          String          @id @default(uuid())
  type        FrameOptionType
  name        String
  label       String?
  slug        String?         @unique
  description String?
  colorHex    String?
  imageUrl    String?
  widthCm     Float?
  heightCm    Float?
  price       Int             @default(0)
  stock       Int?
  minQuantity Int             @default(1)
  maxQuantity Int             @default(99)
  sortOrder   Int             @default(0)
  popular     Boolean         @default(false)
  metadata    Json?
  status      ProductStatus   @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, status])
  @@index([sortOrder])
}

model Order {
  id        String @id @default(uuid())
  orderCode String @unique

  customerName String
  phone        String
  email        String?
  zalo         String?
  address      String
  addressLine  String?
  province     String?
  district     String?
  ward         String?
  receiveDate  DateTime?
  note         String?

  shippingMethod String?
  shippingFee    Int     @default(0)
  voucherCode    String?
  voucherDiscountType  String?
  voucherDiscountValue Int?
  discountAmount Int     @default(0)
  giftPackage    Boolean @default(false)
  giftFee        Int     @default(0)
  polaroidOption String  @default("none")
  polaroidFee    Int     @default(0)

  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus  @default(unpaid)
  orderStatus    OrderStatus    @default(pending)
  shippingStatus ShippingStatus @default(pending)

  itemsAmount     Int       @default(0)
  totalAmount     Int
  depositRequired Boolean   @default(false)
  depositPercent  Int       @default(0)
  depositAmount   Int       @default(0)
  remainingAmount Int       @default(0)
  depositStatus   String    @default("not_required")
  depositPaidAt   DateTime?

  paymentProvider    String?
  payosOrderCode     BigInt? @unique
  payosPaymentLinkId String?
  payosCheckoutUrl   String?

  paidAt      DateTime?
  cancelledAt DateTime?
  expiresAt   DateTime?
  cancelReason String?

  items           OrderItem[]
  payments        Payment[]
  statusHistories OrderStatusHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  productName String
  quantity    Int
  price       Int
  note        String?

  frameOptionId  String?
  backgroundId   String?
  frameSizeId    String?
  frameSizeLabel String?
  frameColorName String?
  accessories    Json?
  designData     Json?
  previewUrl     String?

  createdAt DateTime @default(now())
}

model PaymentSetting {
  id                String  @id @default(uuid())
  codEnabled        Boolean @default(true)
  payosEnabled      Boolean @default(true)
  codDepositEnabled Boolean @default(true)
  codDepositPercent Int     @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Voucher {
  id                String              @id @default(uuid())
  code              String              @unique
  description       String?
  discountType      VoucherDiscountType
  discountValue     Int
  minOrderAmount    Int                 @default(0)
  maxDiscountAmount Int?
  usageLimit        Int?
  usedCount         Int                 @default(0)
  startsAt          DateTime?
  expiresAt         DateTime?
  status            ProductStatus       @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([expiresAt])
}

model Payment {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider              String
  type                  PaymentType
  providerOrderCode     BigInt?
  providerPaymentLinkId String?

  amount      Int
  status      String  @default("pending")
  checkoutUrl String?

  rawResponse Json?
  rawWebhook  Json?

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model OrderStatusHistory {
  id String @id @default(uuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type      OrderStatusHistoryType
  fromValue String?
  toValue   String?
  note      String?

  changedByAdminId String?
  changedByAdmin   Admin?  @relation(fields: [changedByAdminId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([changedByAdminId])
}

model BusinessInquiry {
  id          String @id @default(uuid())
  companyName String
  contactName String
  email       String
  phone       String
  message     String
  status      String @default("new")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  name         String?
  phone        String?

  designs UserDesign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserDesign {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name       String  @default("My Design")
  designData Json
  previewUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
