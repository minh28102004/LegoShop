# Dependencies
node_modules
**/node_modules

# Build outputs
dist
**/dist
build
**/build
.next
**/.next
out
**/out
.turbo
**/.turbo

# Version control & logs
.git
.github
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Môi trường (KHÔNG BAKE VÀO IMAGE)
.env
.env.*
!.env.example

# Development & Test
coverage
**/coverage
*.test.ts
*.spec.ts
jest.config.*
tsconfig.tsbuildinfo
**/tsconfig.tsbuildinfo

# OS files
.DS_Store
Thumbs.db
.vscode
.idea
