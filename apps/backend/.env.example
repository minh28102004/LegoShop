PORT=3000

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
DATABASE_SCHEMA="public"

JWT_SECRET="change-me"
JWT_EXPIRES_IN="7d"

ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PASSWORD="change-this-admin-password"
ADMIN_NAME="Lego Shop Admin"

FRONTEND_URL="http://localhost:3002"
ADMIN_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3001,http://localhost:3002"
CORS_ORIGIN_PATTERNS="https://*.vercel.app"

SHOP_NAME="Lego Shop"

# Authorized sample-media import. Apply/rollback writes remain disabled unless
# this flag is explicitly true. DATABASE_SCHEMA isolates dev/test imports when
# the PostgreSQL provider supports multiple schemas.
IMPORT_SAMPLE_ASSETS="false"
IMPORT_SOURCE_MANIFEST="data/import/theluvin-source.normalized.json"
IMPORT_SEED_TAG="figure-lab-sample-media-20260717"
IMPORT_DOWNLOAD_TIMEOUT_MS=20000
IMPORT_MAX_FILE_BYTES=25000000
IMPORT_MAX_REDIRECTS=5
IMPORT_DOWNLOAD_RETRIES=2
IMPORT_CONCURRENCY=4

# Public origin that serves backend public/uploads (HTTPS outside loopback).
STORAGE_PUBLIC_BASE_URL="http://localhost:3000"
# Filesystem is allowed only for isolated local/test schemas. Imports into
# public must use supabase and an HTTPS public bucket URL.
SAMPLE_MEDIA_STORAGE_PROVIDER="filesystem"
SUPABASE_URL=""
SUPABASE_SECRET_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET=""
# Optional absolute directory containing the uploads folder. When omitted,
# apps/backend/public is discovered from the backend package root.
UPLOAD_ROOT_DIR=""

# Public APIs remain fail-closed unless this is explicitly enabled locally.
INCLUDE_STAGED_SAMPLE_MEDIA="false"
STAGED_SAMPLE_MEDIA_SEED_TAG="figure-lab-full-media-preview-20260717"

PAYOS_BASE_URL="https://api-merchant.payos.vn"
PAYOS_CLIENT_ID=""
PAYOS_API_KEY=""
PAYOS_CHECKSUM_KEY=""
PAYOS_RETURN_URL="http://localhost:3002/payment/success"
PAYOS_CANCEL_URL="http://localhost:3002/payment/cancel"
PAYOS_WEBHOOK_URL="http://localhost:3000/payments/payos/webhook"
