{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "paths": {
      "clsx": ["../../apps/web/node_modules/clsx"],
      "@radix-ui/react-slot": ["../../apps/web/node_modules/@radix-ui/react-slot"],
      "lucide-react": ["../../apps/web/node_modules/lucide-react"],
      "framer-motion": ["../../apps/web/node_modules/framer-motion"],
      "tailwind-merge": ["../../apps/web/node_modules/tailwind-merge"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["dist", "node_modules"]
}
